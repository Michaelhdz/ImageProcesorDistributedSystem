# ── Servidor de Aplicación — Variables de Entorno ─────────────────────────────
# Copiar este archivo como .env y ajustar los valores

# Puerto donde escucha el servidor Express
PORT=3000

# Secreto para firmar los JWT — cambiar en producción
JWT_SECRET=secreto-upb-2025

# Redis — cola de trabajos Bull
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# URL de la API REST interna del Servidor de BD (PC Aula bare metal)
BD_API_URL=http://192.168.1.22:8000

# Clave compartida con los nodos para autenticar el heartbeat
# Debe ser la misma que INTERNAL_API_KEY en el nodo trabajador
INTERNAL_API_KEY=clave-interna-upb-2025

# Número máximo de reintentos para trabajos fallidos en la cola
QUEUE_MAX_ATTEMPTS=3

# Tiempo base de backoff exponencial en ms entre reintentos
QUEUE_BACKOFF_DELAY=2000
